# Hazina Environment Variables

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://hazina:hazina@localhost:5432/hazina

# Redis
REDIS_URL=redis://localhost:6379/0

# App Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# Scraping Intervals
NSE_SCRAPE_INTERVAL_MINUTES=15
NEWS_SCRAPE_INTERVAL_HOURS=2

# Sentiment Fusion (Hybrid: AfriSenti + Claude)
SENTIMENT_MODEL=afrisenti  # Options: afrisenti, claude_only
SENTIMENT_CONFIDENCE_THRESHOLD=0.70  # Below this, skip Claude explanation
ENABLE_CACHED_EXPLANATIONS=true

# Twitter API v2 (for sentiment analysis)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# API Keys (optional - for production)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:5173
